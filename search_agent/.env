SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=info

# 本地大模型（不变）
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
LLM_MODEL=doubao-seed-2-0-lite-260215
LLM_API_KEY=your-api-key-here
LLM_TEMPERATURE=0.2

# DuckDuckGo配置
DDG_REGION=zh-cn          # 搜索区域，默认zh-cn
DDG_MAX_RESULTS=5         # 最大返回结果数，默认5
DDG_TIMEOUT=10            # 搜索超时时间，默认10秒

# 记忆配置
MEMORY_MAX_MESSAGES=10    # 最多保留最近10条对话，默认10